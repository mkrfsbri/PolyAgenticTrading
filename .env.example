# ─── Binance ────────────────────────────────────────────────────────────────
# Partial book depth stream: top-10 levels, updated every 100 ms
BINANCE_WS_URL=wss://stream.binance.com:9443/ws/btcusdt@depth10@100ms

# ─── Polymarket CLOB ────────────────────────────────────────────────────────
# Comma-separated outcome token IDs for the BTC 15-minute Up/Down market.
# Obtain from: GET https://clob.polymarket.com/markets?active=true
# Each binary market produces two tokens (Up token ID, Down token ID).
POLYMARKET_TOKEN_IDS=<UP_TOKEN_ID>,<DOWN_TOKEN_ID>

# ─── QuestDB ────────────────────────────────────────────────────────────────
QUESTDB_HOST=127.0.0.1
QUESTDB_ILP_PORT=9009

# ─── Logging ────────────────────────────────────────────────────────────────
# Levels: trace | debug | info | warn | error
LOG_LEVEL=info
