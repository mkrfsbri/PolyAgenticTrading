# ─── Binance ────────────────────────────────────────────────────────────────
# Partial book depth stream: top-10 levels, updated every 100 ms
BINANCE_WS_URL=wss://stream.binance.com:9443/ws/btcusdt@depth10@100ms

# ─── Polymarket — Auto-Discovery ────────────────────────────────────────────
# The ingestion layer auto-discovers active BTC 15-minute CLOB markets from
# the Gamma API every 60 seconds. New markets are hot-subscribed; expired
# markets are evicted from memory — no restart needed.

# Set to 'false' to disable auto-discovery and rely solely on TOKEN_IDS below.
POLYMARKET_AUTO_DISCOVER=true

# Regex matched against the market slug field (case-insensitive).
# Real format: btc-updown-15m-{unix_timestamp}  e.g. btc-updown-15m-1777049100
# The timestamp suffix increments by 900 s (15 min) per market instance.
# Matching the invariant prefix is sufficient to capture all active instances.
POLYMARKET_SLUG_PATTERN=btc-updown-15m

# How often to poll the Gamma API for market changes (milliseconds).
POLYMARKET_DISCOVER_INTERVAL_MS=60000

# ─── Polymarket CLOB ────────────────────────────────────────────────────────
# Comma-separated outcome token IDs for the BTC 15-minute Up/Down market.
# Each binary market has two tokens: index 0 = Up (YES), index 1 = Down (NO).
#
# Find IDs with the helper script:
#   ./scripts/find-btc-markets.sh "BTC"
#   ./scripts/find-btc-markets.sh "15 min"
#
# Or as a one-liner (requires curl + jq):
#   curl -s "https://gamma-api.polymarket.com/markets?active=true&closed=false&archived=false&enableOrderBook=true&limit=100" \
#     | jq -r '[.[] | select(.question | test("BTC|Bitcoin";"i")) | .clobTokenIds | if type=="string" then fromjson else . end | .[]] | join(",")'
#
# NOTE: clobTokenIds is returned as a stringified JSON by the Gamma API.
#       The script and jq snippet above handle the 'fromjson' parsing for you.
POLYMARKET_TOKEN_IDS=<UP_TOKEN_ID>,<DOWN_TOKEN_ID>

# ─── QuestDB ────────────────────────────────────────────────────────────────
QUESTDB_HOST=127.0.0.1
QUESTDB_ILP_PORT=9009

# ─── Logging ────────────────────────────────────────────────────────────────
# Levels: trace | debug | info | warn | error
LOG_LEVEL=info
